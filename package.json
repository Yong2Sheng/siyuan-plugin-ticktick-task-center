{
  "name": "siyuan-plugin-ticktick-task-center",
  "version": "0.1.0",
  "type": "module",
  "description": "TickTick task cards and a dynamic task center for SiYuan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yong2Sheng/siyuan-plugin-ticktick-task-center.git"
  },
  "homepage": "https://github.com/Yong2Sheng/siyuan-plugin-ticktick-task-center",
  "author": "Yong2Sheng",
  "license": "MIT",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "cross-env NODE_ENV=development VITE_SOURCEMAP=inline vite build --watch",
    "build": "cross-env NODE_ENV=production vite build",
    "test": "vitest run",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "make-link": "node --no-warnings ./scripts/make_dev_link.js",
    "make-link-win": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File ./scripts/elevate.ps1 -scriptPath ./scripts/make_dev_link.js",
    "update-version": "node --no-warnings ./scripts/update_version.js",
    "make-install": "pnpm run build && node --no-warnings ./scripts/make_install.js"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^3.1.0",
    "@types/node": "^20.3.0",
    "cross-env": "^7.0.3",
    "fast-glob": "^3.2.12",
    "rollup-plugin-livereload": "^2.0.5",
    "sass": "^1.63.3",
    "jsdom": "^25.0.1",
    "siyuan": "1.2.2",
    "svelte": "^4.2.20",
    "svelte-check": "^3.8.6",
    "typescript": "^5.1.3",
    "vite": "^5.2.9",
    "vitest": "^2.1.9",
    "vite-plugin-static-copy": "^1.0.2",
    "vite-plugin-zip-pack": "^1.0.5"
  }
}
